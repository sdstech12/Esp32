<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ESP32 Web Flasher + Terminal</title>

<style>

body{
font-family:Arial;
background:#1e1e2f;
color:white;
padding:20px;
max-width:900px;
margin:auto;
}

.container{
background:#2d2d3a;
padding:25px;
border-radius:12px;
}

button{
padding:10px 20px;
border:none;
border-radius:6px;
cursor:pointer;
margin:5px;
font-weight:bold;
}

.primary{background:#6c7cff;color:white;}
.success{background:#4caf50;color:white;}
.danger{background:#ff5252;color:white;}
.warning{background:#ffa726;color:black;}

select,input{
padding:10px;
background:#353542;
border:1px solid #555;
color:white;
border-radius:6px;
}

.log{
background:#111;
padding:15px;
height:250px;
overflow:auto;
font-family:monospace;
margin-top:10px;
border-radius:8px;
}

.tab{
display:inline-block;
padding:10px 20px;
background:#3a3a48;
cursor:pointer;
margin-right:5px;
border-radius:6px;
}

.tab.active{
background:#6c7cff;
}

.panel{display:none;}
.panel.active{display:block;}

.upload{
border:2px dashed #6c7cff;
padding:20px;
text-align:center;
margin:15px 0;
cursor:pointer;
}

.progress{
height:18px;
background:#444;
border-radius:8px;
overflow:hidden;
margin-top:10px;
}

.progress-bar{
height:100%;
background:#4caf50;
width:0%;
}

</style>
</head>

<body>

<div class="container">

<h2>ESP32 Web Flasher + Serial Terminal</h2>

<div>
<span class="tab active" onclick="openTab('flash')">Firmware Flasher</span>
<span class="tab" onclick="openTab('terminal')">Serial Terminal</span>
</div>

<!-- FLASHER -->
<div id="flash" class="panel active">

<div class="upload" onclick="fileInput.click()">
Click to select firmware (.bin)
<input type="file" id="fileInput" hidden accept=".bin">
<div id="fileName">No file selected</div>
</div>

<select id="baud">
<option value="115200">115200 Safe</option>
<option value="460800">460800</option>
<option value="921600" selected>921600 Fast</option>
</select>

<br>

<button class="primary" onclick="selectPort()">Select ESP32</button>
<button class="success" onclick="connectFlash()">Connect</button>
<button class="warning" onclick="flashFirmware()">Flash</button>
<button class="danger" onclick="disconnectFlash()">Disconnect</button>

<div class="progress">
<div id="progressBar" class="progress-bar"></div>
</div>

<div id="flashLog" class="log"></div>

</div>

<!-- TERMINAL -->
<div id="terminal" class="panel">

<select id="terminalBaud">
<option>9600</option>
<option selected>115200</option>
<option>230400</option>
<option>460800</option>
</select>

<br>

<button class="primary" onclick="selectTerminal()">Select Port</button>
<button class="success" onclick="connectTerminal()">Connect</button>
<button class="danger" onclick="disconnectTerminal()">Disconnect</button>
<button class="warning" onclick="clearTerminal()">Clear</button>

<div id="terminalLog" class="log"></div>

<input id="terminalInput" placeholder="Type command">
<button onclick="sendTerminal()">Send</button>

</div>

</div>

<script src="https://unpkg.com/@esphome/esptool-js@0.4.0/dist/webflasher-esptool.js"></script>

<script>

let port;
let transport;
let esploader;
let firmware;

let terminalPort;
let reader;
let writer;
let terminalActive=false;

function log(msg){
let box=document.getElementById("flashLog");
box.innerHTML+=msg+"<br>";
box.scrollTop=box.scrollHeight;
}

function tlog(msg){
let box=document.getElementById("terminalLog");
box.innerHTML+=msg+"<br>";
box.scrollTop=box.scrollHeight;
}

function openTab(name){

document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
document.getElementById(name).classList.add("active");

document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
event.target.classList.add("active");

}

fileInput.onchange=e=>{

let file=e.target.files[0];

document.getElementById("fileName").innerText=file.name;

let reader=new FileReader();

reader.onload=ev=>{
firmware=ev.target.result;
log("Firmware loaded "+file.size+" bytes");
};

reader.readAsArrayBuffer(file);

};

async function selectPort(){

try{
port=await navigator.serial.requestPort();
log("Port selected");
}
catch(e){
log("No port selected");
}

}

async function connectFlash(){

try{

await port.open({
baudRate:parseInt(document.getElementById("baud").value)
});

transport=new EsptoolJS.Transport(port);
esploader=new EsptoolJS.ESPLoader(transport);

log("Connecting to ESP32...");

await esploader.main_fn();

log("Connected to "+esploader.chip.chip_name);

}
catch(e){
log("Connection error "+e);
}

}

async function flashFirmware(){

if(!firmware){
log("Select firmware first");
return;
}

try{

log("Flashing...");

await esploader.write_flash({

fileArray:[
{
data:firmware,
address:0x10000
}
],

eraseAll:true,

reportProgress:(cur,total)=>{

let percent=Math.round(cur/total*100);

document.getElementById("progressBar").style.width=percent+"%";

}

});

log("Flash complete. Press RESET.");

}
catch(e){

log("Flash error "+e);

}

}

async function disconnectFlash(){

try{
await port.close();
log("Disconnected");
}
catch(e){}

}

async function selectTerminal(){

terminalPort=await navigator.serial.requestPort();
tlog("Port selected");

}

async function connectTerminal(){

await terminalPort.open({
baudRate:parseInt(document.getElementById("terminalBaud").value)
});

terminalActive=true;

const decoder=new TextDecoderStream();
terminalPort.readable.pipeTo(decoder.writable);

reader=decoder.readable.getReader();

const encoder=new TextEncoderStream();
encoder.readable.pipeTo(terminalPort.writable);

writer=encoder.writable.getWriter();

readLoop();

tlog("Terminal connected");

}

async function readLoop(){

while(terminalActive){

let {value,done}=await reader.read();

if(done)break;

if(value)tlog(value);

}

}

async function sendTerminal(){

let txt=document.getElementById("terminalInput").value+"\n";

await writer.write(txt);

document.getElementById("terminalInput").value="";

}

async function disconnectTerminal(){

terminalActive=false;

await terminalPort.close();

tlog("Terminal disconnected");

}

function clearTerminal(){

document.getElementById("terminalLog").innerHTML="";

}

</script>

</body>
</html>
