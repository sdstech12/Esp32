<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Android ESP32 Flasher</title>
    <style>
        body { font-family: sans-serif; background: #121212; color: #fff; padding: 20px; margin: 0; text-align: center; }
        .card { background: #1e1e1e; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); max-width: 500px; margin: auto; }
        button { 
            width: 100%; padding: 15px; margin: 10px 0; border-radius: 10px; border: none; 
            font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.3s;
        }
        .btn-connect { background: #3498db; color: white; }
        .btn-flash { background: #27ae60; color: white; }
        .btn-flash:disabled { background: #444; color: #888; }
        #log { 
            background: #000; color: #0f0; padding: 10px; height: 150px; 
            overflow-y: auto; font-family: monospace; font-size: 12px; 
            border-radius: 8px; text-align: left; margin-top: 20px;
        }
        .status { margin: 10px 0; padding: 10px; border-radius: 8px; font-weight: bold; display: none; }
    </style>
</head>
<body>

    <div class="card">
        <h2>ESP32 Android Flash</h2>
        <div id="statusBox" class="status"></div>

        <button class="btn-connect" id="btnConnect">🔌 1. Connect ESP32</button>
        
        <p style="font-size: 14px; color: #bbb;">2. Select Firmware (.bin)</p>
        <input type="file" id="fileInput" accept=".bin" style="margin-bottom: 10px;">

        <button class="btn-flash" id="btnFlash" disabled>⚡ 3. Start Flashing</button>
        
        <div id="log">Logs will appear here...</div>
    </div>

    <script src="https://unpkg.com/@esphome/esptool-js@0.4.0/dist/webflasher-esptool.js"></script>

    <script>
        let port, esploader, fileData;
        const logEl = document.getElementById('log');
        const statusEl = document.getElementById('statusBox');

        function log(msg) {
            logEl.innerHTML += `<div>> ${msg}</div>`;
            logEl.scrollTop = logEl.scrollHeight;
        }

        function setStatus(msg, color) {
            statusEl.style.display = 'block';
            statusEl.style.background = color;
            statusEl.innerText = msg;
        }

        // CONNECT LOGIC
        document.getElementById('btnConnect').onclick = async () => {
            try {
                log("Requesting Port...");
                // Filterless request for Android compatibility
                port = await navigator.serial.requestPort({}); 
                
                await port.open({ baudRate: 115200 });
                const transport = new EsptoolJS.Transport(port);
                esploader = new EsptoolJS.ESPLoader(transport);
                
                setStatus("Syncing...", "#f39c12");
                await esploader.main_fn();
                const chip = await esploader.chip;
                
                setStatus(`Connected: ${chip.chip_name}`, "#27ae60");
                log("Found: " + chip.chip_name);
                
                if (fileData) document.getElementById('btnFlash').disabled = false;
            } catch (err) {
                log("Error: " + err.message);
                setStatus("Connection Failed", "#e74c3c");
            }
        };

        // FILE LOAD LOGIC
        document.getElementById('fileInput').onchange = (e) => {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = (ev) => {
                fileData = ev.target.result;
                log("File Loaded: " + file.name);
                if (esploader) document.getElementById('btnFlash').disabled = false;
            };
            reader.readAsBinaryString(file);
        };

        // FLASH LOGIC
        document.getElementById('btnFlash').onclick = async () => {
            try {
                log("Flashing started...");
                await esploader.write_flash({
                    fileArray: [{ data: fileData, address: 0x1000 }],
                    flashSize: 'keep',
                    reportProgress: (curr, total) => {
                        const pct = Math.round((curr / total) * 100);
                        setStatus(`Flashing: ${pct}%`, "#3498db");
                    }
                });
                setStatus("Success!", "#27ae60");
                log("✅ Done! Press Reset on ESP32.");
            } catch (err) {
                log("Flash Error: " + err.message);
                setStatus("Flash Failed", "#e74c3c");
            }
        };
    </script>
</body>
</html>
